# The hostname of our Redis server. In Docker Compose, this usually matches the service name (redis).
REDIS_HOST=redis  

# The port Redis is listening on (default 6379).
REDIS_PORT=6379

#Database 0 for celery task messages
REDIS_DB_TASKS=0

#Database 1 for Celery task result
REDIS_DB_RESULTS=1

#Database 2 is reserved for any other app-specific chaching
REDIS_DB_APP=2

#Number of Celery worker processes that will run your tasks in parallel.
#Each worker will pull tasks from Redis and execute them. More workers = higher throughput, but higher CPU/memory usage.
CELERY_WORKERS=2

#Number of instances of our API service to run (useful for load balancing in Docker Swarm or Kubernetes).
API_REPLICAS=3

# MLflow tracking server URI, used by our mlflow_logger.py to log experiments and metrics.
MLFLOW_URI=http://mlflow:5000

# controls what gets logged (info, debug, errors)
LOG_LEVEL=INFO 

#prevents Celery tasks from hanging forever
CELERY_TASK_TIMEOUT=300

# prevents the API call itself from hanging
API_REQUEST_TIMEOUT=120

PUSHGATEWAY=http://pushgateway:9091